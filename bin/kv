#!/usr/bin/env node

const { execSync } = require('child_process');
const readline = require('readline');
const keychain = require('../src/keychain');

const VERSION = '0.1.0';
const CLIP_CLEAR_SECONDS = 60;

// Colors
const c = {
  red: s => `\x1b[0;31m${s}\x1b[0m`,
  green: s => `\x1b[0;32m${s}\x1b[0m`,
  yellow: s => `\x1b[0;33m${s}\x1b[0m`,
  cyan: s => `\x1b[0;36m${s}\x1b[0m`,
  dim: s => `\x1b[2m${s}\x1b[0m`,
};

function die(msg) {
  console.error(`${c.red('error:')} ${msg}`);
  process.exit(1);
}

function info(msg) {
  console.log(`${c.green('ok:')} ${msg}`);
}

function warn(msg) {
  console.log(`${c.yellow('warn:')} ${msg}`);
}

// --- Commands ---

function cmdInit() {
  if (keychain.isInitialized()) {
    die('already initialized. Use "kv passwd" to change master password.');
  }

  console.log(`${c.cyan('Setting up kv...')}\n`);

  const pw1 = keychain.promptPassword('  Create master password: ');
  if (!pw1) die('password cannot be empty');

  const pw2 = keychain.promptPassword('  Confirm master password: ');
  if (pw1 !== pw2) die('passwords do not match');

  keychain.init(pw1);
  info('initialized. Keys stored in ~/.kv/kv.keychain-db');
  console.log(`\n  ${c.dim('Auto-locks after 8 hours. Unlock with master password.')}`);
}

function cmdPasswd() {
  const oldPw = keychain.promptPassword('  Current password: ');
  const newPw = keychain.promptPassword('  New password: ');
  if (!newPw) die('password cannot be empty');
  const confirmPw = keychain.promptPassword('  Confirm new password: ');
  if (newPw !== confirmPw) die('passwords do not match');

  const count = keychain.changePassword(oldPw, newPw);
  info(`password changed. ${count} keys migrated.`);
}

async function cmdSet(args) {
  const name = args[0];
  let value = args[1];

  if (!name) die('usage: kv set <name> [value]');

  if (!value) {
    if (process.stdin.isTTY) {
      value = keychain.promptPassword(`${c.cyan('Enter value for ')}${name}${c.cyan(':')} `);
    } else {
      value = await new Promise((resolve) => {
        let data = '';
        process.stdin.setEncoding('utf-8');
        process.stdin.on('data', chunk => data += chunk);
        process.stdin.on('end', () => resolve(data.trim()));
      });
    }
    if (!value) die('value cannot be empty');
  }

  keychain.set(name, value);
  info(`stored ${c.cyan(name)}`);
}

function cmdGet(args) {
  let name = '';
  let printMode = false;

  for (const arg of args) {
    if (arg === '--print' || arg === '-p') printMode = true;
    else if (arg.startsWith('-')) die(`unknown flag: ${arg}`);
    else name = arg;
  }

  if (!name) die('usage: kv get <name> [--print]');

  const value = keychain.get(name);

  if (printMode) {
    process.stdout.write(value + '\n');
  } else {
    execSync('pbcopy', { input: value });
    info(`copied ${c.cyan(name)} to clipboard (clears in ${CLIP_CLEAR_SECONDS}s)`);

    const child = require('child_process').spawn('bash', ['-c',
      `sleep ${CLIP_CLEAR_SECONDS} && current=$(pbpaste 2>/dev/null) && [ "$current" = '${value.replace(/'/g, "'\\''")}' ] && echo -n "" | pbcopy`
    ], { detached: true, stdio: 'ignore' });
    child.unref();
  }
}

function cmdList(args) {
  const prefix = args[0] || '';
  const items = keychain.list(prefix || undefined);

  if (items.length === 0) {
    warn(prefix ? `no keys matching: ${prefix}` : 'no keys stored');
    return;
  }

  console.log(c.dim('NAME'));
  for (const item of items) {
    console.log(`  ${item}`);
  }
}

function cmdGroups() {
  const { grouped, ungrouped } = keychain.groups();

  if (Object.keys(grouped).length === 0 && ungrouped.length === 0) {
    warn('no keys stored');
    return;
  }

  console.log(`${c.dim('GROUP')}                          ${c.dim('KEYS')}`);

  const sorted = Object.entries(grouped).sort((a, b) => b[1] - a[1]);
  for (const [name, count] of sorted) {
    console.log(`  ${c.cyan(`${name}/`.padEnd(28))} ${count}`);
  }

  if (ungrouped.length > 0) {
    console.log(`  ${c.dim(`(ungrouped)`.padEnd(28))} ${c.dim(ungrouped.length)}`);
  }
}

function cmdRm(args) {
  let name = '';
  let rmAll = false;

  for (const arg of args) {
    if (arg === '--all' || arg === '-a') rmAll = true;
    else if (arg.startsWith('-')) die(`unknown flag: ${arg}`);
    else name = arg;
  }

  if (!name) die('usage: kv rm <name> [--all]');

  if (rmAll) {
    const count = keychain.rmGroup(name);
    info(`deleted ${c.cyan(count)} keys matching ${c.cyan(name)}`);
  } else {
    keychain.rm(name);
    info(`deleted ${c.cyan(name)}`);
  }
}

function cmdEnv(args) {
  const prefix = args[0];
  if (!prefix) die('usage: kv env <prefix>');

  const vars = keychain.env(prefix);
  for (const [key, value] of Object.entries(vars)) {
    console.log(`${key}=${value}`);
  }
}

function cmdStatus() {
  if (!keychain.isInitialized()) {
    console.log(`${c.yellow('not initialized')} — run ${c.cyan('kv init')}`);
    return;
  }
  const locked = !keychain.isUnlocked();
  console.log(`${c.cyan('kv')} v${VERSION}`);
  console.log(`  status:  ${locked ? c.yellow('locked 🔒') : c.green('unlocked 🔓')}`);
  console.log(`  store:   ~/.kv/kv.keychain-db`);
  try {
    const items = keychain.getAllItems();
    console.log(`  keys:    ${items.length}`);
  } catch {
    console.log(`  keys:    ${c.dim('(unlock to view)')}`);
  }
}

function cmdHelp() {
  console.log(`${c.cyan('kv')} v${VERSION} - Secure API key storage via macOS Keychain

${c.yellow('SETUP')}
  kv init                 Set master password & create encrypted store
  kv passwd               Change master password
  kv status               Show lock status & key count

${c.yellow('COMMANDS')}
  set <name> [value]      Store a key (omit value for secure input)
  get <name> [--print]    Retrieve a key (default: clipboard, 10s clear)
  list [prefix]           List stored key names
  groups                  Show all groups with key counts
  rm <name> [--all]       Delete a key or all keys in a group
  env <prefix>            Export keys as KEY=VALUE format

${c.yellow('EXAMPLES')}
  kv set openai sk-proj-xxxxx
  kv set openai                       ${c.dim('# secure hidden input')}
  echo "sk-xxx" | kv set openai       ${c.dim('# pipe (avoids shell history)')}
  kv get openai                       ${c.dim('# copy to clipboard')}
  kv get openai --print               ${c.dim('# print to terminal')}
  kv groups                           ${c.dim('# show all groups')}
  kv rm openrouter/ --all             ${c.dim('# delete entire group')}

${c.yellow('NODE.JS API')}
  const { kv } = require('@safe-labs/kv')
  const key = kv('openrouter')

${c.yellow('SECURITY')}
  - Encrypted keychain with master password (~/.kv/kv.keychain-db)
  - Auto-locks after 8 hours, re-enter password once to unlock
  - Clipboard auto-clears after ${CLIP_CLEAR_SECONDS}s
  - Use secure input or pipe to avoid shell history leaks`);
}

// --- Main ---

const [command = 'help', ...args] = process.argv.slice(2);

const commands = {
  init: () => cmdInit(),
  passwd: () => cmdPasswd(),
  status: () => cmdStatus(),
  set: () => cmdSet(args),
  get: () => cmdGet(args),
  list: () => cmdList(args),
  ls: () => cmdList(args),
  groups: () => cmdGroups(),
  rm: () => cmdRm(args),
  delete: () => cmdRm(args),
  env: () => cmdEnv(args),
  help: cmdHelp,
  '--help': cmdHelp,
  '-h': cmdHelp,
  version: () => console.log(`kv v${VERSION}`),
  '--version': () => console.log(`kv v${VERSION}`),
  '-v': () => console.log(`kv v${VERSION}`),
};

const fn = commands[command];
if (!fn) die(`unknown command: ${command} (try 'kv help')`);

try {
  const result = fn();
  if (result && typeof result.catch === 'function') {
    result.catch(err => die(err.message));
  }
} catch (err) {
  die(err.message);
}
